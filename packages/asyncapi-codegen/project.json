{
  "name": "asyncapi-codegen",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/asyncapi-codegen/src",
  "projectType": "library",
  "targets": {
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run format",
        "cwd": "packages/asyncapi-codegen"
      }
    },
    "format.check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run format.check",
        "cwd": "packages/asyncapi-codegen"
      },
      "cache": true
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm pack --dry-run",
        "cwd": "packages/asyncapi-codegen"
      }
    },
    "codegen:run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node packages/asyncapi-codegen/src/cli.mjs",
        "forwardAllArgs": true
      }
    }
  },
  "tags": []
}
