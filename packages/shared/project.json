{
  "name": "@rvct/shared",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/shared/src",
  "projectType": "library",
  "namedInputs": {
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/jest.config.[jt]s",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/eslint.config.[jt]s"
    ]
  },
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --project tsconfig.lib.json --watch",
        "cwd": "packages/shared"
      },
      "continuous": true
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --project tsconfig.lib.json --watch",
        "cwd": "packages/shared"
      },
      "continuous": true
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --ignore-path ../../.prettierignore --write .",
        "cwd": "packages/shared"
      }
    },
    "format-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --ignore-path ../../.prettierignore --check .",
        "cwd": "packages/shared"
      },
      "cache": true,
      "inputs": ["production", "^production"]
    },
    "build": {
      "cache": true,
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"]
    },
    "codegen:openapi": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["ash_framework"],
          "target": "codegen:openapi",
          "params": "ignore"
        }
      ],
      "options": {
        "commands": ["pnpm exec kubb generate --config kubb.config.ts"],
        "parallel": false
      },
      "outputs": ["{projectRoot}/src/api"]
    },
    "codegen:asyncapi": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run asyncapi-codegen:codegen:run -- --input apps/ash_framework/priv/specs/asyncapi.yaml --out packages/shared/src/asyncapi"
      }
    }
  },
  "tags": []
}
