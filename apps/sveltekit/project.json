{
  "name": "sveltekit",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/sveltekit/src",
  "projectType": "application",
  "namedInputs": {
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)",
      "!{projectRoot}/**/?(*.)+(spec|test).svelte",
      "!{projectRoot}/eslint.config.[jt]s"
    ]
  },
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run dev -- --host 0.0.0.0",
        "cwd": "apps/sveltekit"
      },
      "continuous": true
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run start",
        "cwd": "apps/sveltekit"
      },
      "dependsOn": ["build"]
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run preview -- --host 0.0.0.0",
        "cwd": "apps/sveltekit"
      },
      "continuous": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run check",
        "cwd": "apps/sveltekit"
      },
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run lint",
        "cwd": "apps/sveltekit"
      },
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run format",
        "cwd": "apps/sveltekit"
      }
    },
    "format-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run format:check",
        "cwd": "apps/sveltekit"
      },
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run test",
        "cwd": "apps/sveltekit"
      },
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run build",
        "cwd": "apps/sveltekit"
      },
      "cache": true,
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/build", "{projectRoot}/.svelte-kit/output"]
    }
  },
  "tags": []
}
