{
  "name": "nextjs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/nextjs/src",
  "projectType": "application",
  "namedInputs": {
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/jest.config.[jt]s"
    ]
  },
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev --webpack",
        "cwd": "apps/nextjs"
      },
      "continuous": true
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev --webpack",
        "cwd": "apps/nextjs"
      },
      "continuous": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "apps/nextjs"
      },
      "cache": true,
      "inputs": ["production", "^production"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run lint",
        "cwd": "apps/nextjs"
      },
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run format",
        "cwd": "apps/nextjs"
      }
    },
    "format.check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run format.check",
        "cwd": "apps/nextjs"
      },
      "cache": true,
      "inputs": ["production", "^production"]
    },
    "build": {
      "cache": true,
      "outputs": ["{projectRoot}/.next", "!{projectRoot}/.next/standalone"]
    }
  },
  "tags": []
}
